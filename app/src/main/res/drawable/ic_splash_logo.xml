<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!--
      Android 12+ Splash Screens mask the icon into a circle.
      To ensure the square logo looks like a square and doesn't get clipped
      by that circle, we scale it down to fit entirely within the circular safe area.
    -->
    <group
        android:translateX="27.5"
        android:translateY="27.5"
        android:scaleX="0.45"
        android:scaleY="0.45">

        <!-- White Square Background (the "box") -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M0,0 h100 v100 h-100 z" />

        <!-- Blue House Shape (Bottom-Right aligned) -->
        <path
            android:fillColor="#3022A6"
            android:pathData="M25,99 L70,52 L99,70 V99 H25 Z" />

        <!-- 2x2 White Window Grid -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M80,80 h8 v8 h-8 z M89,80 h8 v8 h-8 z M80,89 h8 v8 h-8 z M89,89 h8 v8 h-8 z" />
    </group>
</vector>
